<Window x:Class="MindMapBookWriter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:MindMapBookWriter.Controls"
        mc:Ignorable="d"
        Title="MindMap Book Writer" 
        Height="800" 
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Barre d'outils -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo et titre -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="📚" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="MindMap Book Writer" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Titre du livre -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Livre:" Foreground="White" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding BookStructure.Title, UpdateSourceTrigger=PropertyChanged}" 
                             Width="250" 
                             FontSize="14"
                             materialDesign:HintAssist.Hint="Titre du livre"/>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="📁 Sélectionner dossier" 
                            Command="{Binding SelectProjectFolderCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Margin="5,0"/>
                    <Button Content="➕ Nouveau Chapitre" 
                            Command="{Binding AddChapterCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{StaticResource PrimaryBrush}"
                            Margin="5,0"/>
                    <Button Content="💾 Sauvegarder" 
                            Command="{Binding SaveProjectCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="{StaticResource SecondaryBrush}"
                            Margin="5,0"/>
                    <Button Content="📂 Charger" 
                            Command="{Binding LoadProjectCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Margin="5,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Contenu principal -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Barre latérale -->
            <Border Grid.Column="0" Background="White" BorderBrush="#DEE2E6" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="📋 Structure du Livre" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Margin="15,15,15,10"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding BookStructure.Chapters}" Margin="10">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" 
                                            BorderBrush="#E0E0E0" 
                                            BorderThickness="1" 
                                            CornerRadius="5" 
                                            Margin="0,0,0,10"
                                            Padding="10">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Chapitre -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" 
                                                          Text="{Binding Name}" 
                                                          FontWeight="SemiBold" 
                                                          FontSize="14"
                                                          VerticalAlignment="Center"/>

                                                <Button Grid.Column="1" 
                                                        Content="➕" 
                                                        ToolTip="Ajouter une scène"
                                                        Command="{Binding DataContext.AddSceneCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                        Width="24" Height="24"
                                                        Margin="5,0"/>

                                                <Button Grid.Column="2" 
                                                        Content="🗑️" 
                                                        ToolTip="Supprimer le chapitre"
                                                        Command="{Binding DataContext.DeleteChapterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                        Width="24" Height="24"/>
                                            </Grid>

                                            <!-- Scènes -->
                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding Scenes}" Margin="10,5,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#F8F9FA" 
                                                                BorderBrush="#E0E0E0" 
                                                                BorderThickness="1" 
                                                                CornerRadius="3" 
                                                                Margin="0,3,0,0"
                                                                Padding="8,5">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <TextBlock Grid.Column="0" 
                                                                          Text="{Binding Name, StringFormat='📝 {0}'}" 
                                                                          FontSize="12"
                                                                          VerticalAlignment="Center"
                                                                          Cursor="Hand">
                                                                    <TextBlock.InputBindings>
                                                                        <MouseBinding MouseAction="LeftClick" 
                                                                                    Command="{Binding DataContext.SelectSceneCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                    CommandParameter="{Binding}"/>
                                                                    </TextBlock.InputBindings>
                                                                </TextBlock>

                                                                <Button Grid.Column="1" 
                                                                        Content="🗑️" 
                                                                        Command="{Binding DataContext.DeleteSceneCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                                        Width="20" Height="20"
                                                                        FontSize="10"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Zone de travail -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Sélecteur de vue -->
                <Border Grid.Row="0" Background="#F8F9FA" BorderBrush="#DEE2E6" BorderThickness="0,0,0,1" Padding="15,10">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="🗺️ Carte Mentale" 
                                    IsChecked="{Binding IsMindMapView}"
                                    Style="{StaticResource MaterialDesignTabRadioButton}"
                                    Margin="0,0,10,0"/>
                        <RadioButton Content="✍️ Éditeur" 
                                    IsChecked="{Binding IsMindMapView, Converter={StaticResource InverseBoolConverter}}"
                                    Style="{StaticResource MaterialDesignTabRadioButton}"/>
                    </StackPanel>
                </Border>

                <!-- Contenu -->
                <Grid Grid.Row="1">
                    <!-- Carte mentale -->
                    <local:MindMapControl x:Name="MindMapControl"
                                         Nodes="{Binding MindMapNodes}"
                                         Connections="{Binding MindMapConnections}"
                                         Visibility="{Binding IsMindMapView, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- Éditeur -->
                    <Grid Visibility="{Binding IsMindMapView, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- En-tête éditeur -->
                        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="20,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding SelectedChapter.Name, StringFormat='📚 {0}'}" 
                                              FontSize="18" 
                                              FontWeight="Bold"/>
                                    <TextBlock Text="{Binding SelectedScene.Name, StringFormat='📝 {0}'}" 
                                              FontSize="14" 
                                              Foreground="#666"
                                              Margin="0,5,0,0"/>
                                </StackPanel>

                                <Button Grid.Column="1" 
                                       Content="💾 Sauvegarder cette scène"
                                       Command="{Binding SaveProjectCommand}"
                                       Style="{StaticResource MaterialDesignRaisedButton}"
                                       Background="{StaticResource PrimaryBrush}"/>
                            </Grid>
                        </Border>

                        <!-- Éditeur de texte -->
                        <TextBox Grid.Row="1" 
                                Text="{Binding CurrentSceneContent, UpdateSourceTrigger=PropertyChanged}"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                VerticalScrollBarVisibility="Auto"
                                FontFamily="Consolas"
                                FontSize="14"
                                Padding="20"
                                Background="White"
                                BorderThickness="0"
                                materialDesign:HintAssist.Hint="Écrivez votre scène ici en Markdown..."/>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
